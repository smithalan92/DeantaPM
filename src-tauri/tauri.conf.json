{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Déanta",
  "version": "0.1.0",
  "identifier": "com.deanta",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "macOS": {
      "bundleName": "Déanta"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3NkM4MzJFOTYwNDM4QjIKUldTeU9BU1dMb05zcHlmVy9oSE5DT05uaEg2OVZiS1hHbHRYQmN4ZjZOVThyWk92Q2VsaG5GeWYK",
      "endpoints": ["https://github.com/smithalan92/DeantaPM/releases/latest/download/latest.json"]
    }
  }
}
